# Server
HOST=127.0.0.1
PORT=8000
RELOAD=false

# Log level (DEBUG, INFO, WARNING, ERROR, CRITICAL)
LOG_LEVEL=INFO

# CORS
CORS_POLICY_ORIGIN=*

# Irodori TTS model
DEFAULT_MODEL=Aratako/Irodori-TTS-600M-v3-VoiceDesign
CODEC_REPO=Aratako/Semantic-DACVAE-Japanese-32dim
MODEL_DEVICE=cuda
CODEC_DEVICE=cpu
MODEL_PRECISION=fp32
# GPUの可視性（空欄=OSのデフォルトを使用、例: "0" でGPU 0のみ公開）
CUDA_VISIBLE_DEVICES=

# 推論の並列度（1=直列、2以上=GPUでの並行推論 vram容量に依存）
MAX_PARALLELISM=4

# ウォーターマーク（デフォルトは無効、trueに設定するとSilentCipherを有効化）
ENABLE_WATERMARK=false

# 長文分割推論で1バッチあたりに同時処理するセグメント最大数の上限
# リクエスト側の maxBatchSegments はこの値を超えられない
MAX_BATCH_SEGMENTS=8

# データディレクトリ
MODELS_DIR=models
DATA_DIR=data

# Limits
MAX_REF_SECONDS=30.0
MAX_GENERATE_SECONDS=30.0
MAX_NUM_CANDIDATES=4
MAX_REQUEST_BODY_SIZE=33554432
