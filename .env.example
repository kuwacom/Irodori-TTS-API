# Server
HOST=127.0.0.1
PORT=8000
RELOAD=false

# Log level (DEBUG, INFO, WARNING, ERROR, CRITICAL)
LOG_LEVEL=INFO

# CORS
CORS_POLICY_ORIGIN=*

# Irodori TTS model
DEFAULT_MODEL=Aratako/Irodori-TTS-600M-v3-VoiceDesign
CODEC_REPO=Aratako/Semantic-DACVAE-Japanese-32dim
MODEL_DEVICE=cuda
CODEC_DEVICE=cpu
MODEL_PRECISION=fp32

# GPU visibility (empty = use OS default, e.g. "0" to expose only GPU 0)
CUDA_VISIBLE_DEVICES=

# Directories
MODELS_DIR=models
DATA_DIR=data

# Limits
MAX_REF_SECONDS=30.0
MAX_GENERATE_SECONDS=30.0
MAX_NUM_CANDIDATES=4
MAX_REQUEST_BODY_SIZE=33554432
